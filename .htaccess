# Disable directory browsing
Options -Indexes

# Protect sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set base path for subfolder installation
    # If folder name is BISTRO_POS (no space), uncomment the line below:
    RewriteBase /BISTRO_POS/
    # If folder name is BISTRO POS (with space), use this instead:
    # RewriteBase /BISTRO%20POS/
    
    # Block access to app folder
    RewriteRule ^app/ - [F,L]
    
    # Block access to system folder
    RewriteRule ^system/ - [F,L]
    
    # Block access to writable folder
    RewriteRule ^writable/ - [F,L]
    
    # Block access to tests folder
    RewriteRule ^tests/ - [F,L]
    
    # Block access to vendor folder (if exists)
    RewriteRule ^vendor/ - [F,L]
    
    # Block access to .env file
    RewriteRule ^\.env$ - [F,L]
    
    # Allow access to public folder assets
    RewriteCond %{REQUEST_URI} ^/public/(.*)$
    RewriteRule ^public/(.*)$ public/$1 [L]
    
    # Redirect Trailing Slashes...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]
    
    # Rewrite "www.example.com -> example.com"
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]
    
    # Checks to see if the user is attempting to access a valid file,
    # such as an image or css document, if this isn't true it sends the
    # request to the front controller, index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]
    
    # Ensure Authorization header is passed along
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule !mod_rewrite.c>
    # If we don't have mod_rewrite installed, all 404's
    # can be sent to index.php, and everything works as normal.
    ErrorDocument 404 index.php
</IfModule>

# Disable server signature
ServerSignature Off
